{
  "$id": "https://spec.tsl.network/schemas/production_readiness_evidence.v1.schema.json",
  "type": "object",
  "required": ["type", "status", "owner", "review_date", "approver", "release_decision", "items"],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "tsl.production_readiness_evidence.v1" },
    "status": { "enum": ["missing", "draft", "reviewed", "approved", "rejected"] },
    "owner": { "type": "string", "minLength": 1 },
    "review_date": { "type": ["string", "null"], "format": "date-time" },
    "approver": { "type": ["string", "null"] },
    "release_decision": { "enum": ["blocked", "approved", "rejected"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "owner",
          "review_date",
          "approver",
          "evidence_links",
          "blocking_findings",
          "release_decision"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "enum": ["missing", "draft", "reviewed", "approved", "rejected"] },
          "owner": { "type": "string", "minLength": 1 },
          "review_date": { "type": ["string", "null"], "format": "date-time" },
          "approver": { "type": ["string", "null"] },
          "evidence_links": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "blocking_findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "severity", "status", "description"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "severity": { "enum": ["low", "medium", "high", "critical"] },
                "status": { "enum": ["open", "mitigated", "accepted", "closed"] },
                "description": { "type": "string", "minLength": 1 }
              }
            }
          },
          "release_decision": { "enum": ["blocked", "approved", "rejected"] }
        }
      }
    }
  }
}
