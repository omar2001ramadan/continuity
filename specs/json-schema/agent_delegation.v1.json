{
  "$id": "https://spec.tsl.network/schemas/agent_delegation.v1.json",
  "type": "object",
  "required": [
    "type",
    "controller",
    "controller_key_id",
    "agent",
    "agent_key_id",
    "scope",
    "issued_at",
    "expires_at",
    "nonce",
    "controller_signature",
    "agent_signature"
  ],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "tsl.agent_delegation.v1" },
    "controller": { "type": "string", "pattern": "^did:tsl:" },
    "controller_key_id": { "type": "string" },
    "agent": { "type": "string", "pattern": "^did:tsl:" },
    "agent_key_id": { "type": "string" },
    "session_key": { "type": "string" },
    "max_uses": { "type": "integer", "minimum": 1 },
    "spending_limit_commitment": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "nonce": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "controller_signature": { "type": "string", "pattern": "^0x[0-9a-f]+$" },
    "agent_signature": { "type": "string", "pattern": "^0x[0-9a-f]+$" }
  }
}
