{
  "$id": "https://spec.tsl.network/schemas/trust_assessment.v1.json",
  "type": "object",
  "required": [
    "type",
    "subject",
    "issuer",
    "score_bps",
    "label",
    "model_version",
    "evidence_commitment",
    "issued_at",
    "expires_at",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "tsl.trust_assessment.v1" },
    "subject": { "type": "string", "pattern": "^did:tsl:" },
    "issuer": { "type": "string", "pattern": "^did:tsl:" },
    "score_bps": { "type": "integer", "minimum": 0, "maximum": 10000 },
    "label": { "enum": ["trusted", "likely_trusted", "medium_trust", "unknown_caution", "suspicious", "high_risk", "revoked", "insufficient_evidence"] },
    "model_version": { "type": "string" },
    "evidence_commitment": { "type": "string", "pattern": "^0x[0-9a-f]{64}$" },
    "features_disclosed": { "type": "array", "items": { "type": "string" } },
    "explanation": { "type": "array", "items": { "type": "string" } },
    "issued_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "type": "string", "pattern": "^0x[0-9a-f]+$" }
  }
}
