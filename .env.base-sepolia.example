TSL_SETTLEMENT_BACKEND=eip155:84532
TSL_SETTLEMENT_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
TSL_BASE_SEPOLIA_PRIVATE_KEY=
TSL_BASE_SEPOLIA_RELAY_IDS=did:tsl:relay:base-sepolia
TSL_BASE_SEPOLIA_RELAY_SIGNER=

# Filled by npm run deploy:base-sepolia.
TSL_CHECKPOINT_REGISTRY_ADDRESS=
TSL_TRUST_ID_REGISTRY_ADDRESS=
TSL_REVOCATION_REGISTRY_ADDRESS=
TSL_PROVIDER_REGISTRY_ADDRESS=
TSL_GOVERNANCE_REGISTRY_ADDRESS=

TSL_RELAY_ID=did:tsl:relay:base-sepolia
TSL_RELAY_PRIVATE_KEY_URI=env
TSL_SCORING_PROVIDER_ID=did:tsl:provider:base-sepolia
TSL_SCORING_PROVIDER_SEED_HEX=
TSL_AUDITOR_ID=did:tsl:auditor:base-sepolia
TSL_AUDITOR_SEED_HEX=
TSL_DATABASE_URL=postgres://tsl:change_me@postgres:5432/tsl
TSL_QUEUE_URL=redis://redis:6379
TSL_EPOCH_MS=300000
TSL_REQUIRE_SETTLEMENT=true
